# ---- Core ----
APP_ENV=development
APP_SECRET=change-me-to-a-long-random-string
PUBLIC_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ---- Model checkpoint ----
# Path inside the backend container. `make smoke-train` produces runs/smoke/final.pt
ARIA_CHECKPOINT=runs/smoke/final.pt
ARIA_TOKENIZER=runs/smoke/tokenizer.json
ARIA_DEVICE=auto                  # auto | cpu | cuda
ARIA_MAX_NEW_TOKENS=512
ARIA_DEFAULT_TEMPERATURE=0.8
ARIA_DEFAULT_TOP_P=0.95
ARIA_DEFAULT_TOP_K=50

# ---- Database ----
POSTGRES_USER=aria
POSTGRES_PASSWORD=aria
POSTGRES_DB=aria
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://aria:aria@db:5432/aria

# ---- Redis (optional, used for rate-limit & request queue) ----
REDIS_URL=redis://redis:6379/0

# ---- Limits ----
MAX_UPLOAD_MB=20
MAX_FETCH_BYTES=2000000
RATE_LIMIT_PER_MINUTE=60

# ---- Auth (optional API key for /api/*) ----
ARIA_API_KEY=

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=http://localhost:8000
